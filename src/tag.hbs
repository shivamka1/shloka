{{!< default}}

<header id="blog-header"{{#if tag.feature_image}} class="has-cover"{{else}}{{#if @site.cover_image}} class="has-cover"{{/if}}{{/if}}>
	<div class="inner">
		<nav id="navigation">
		</nav>
		<h1 class="blog-name">{{tag.name}}</h1>
		{{#if tag.description}}
		<span class="blog-description">{{tag.description}}</span>
		{{/if}}
		<div class="post-count">{{t "Posts"}}: <span class="post-count-number">{{pagination.total}}</span></div>
		{{#if tag.feature_image}}
		<div class="blog-cover cover" style="background-image: url('{{img_url tag.feature_image}}');"></div>
		{{else}}
		{{#if @site.cover_image}}
		<div class="blog-cover cover" style="background-image: url('{{img_url @site.cover_image}}');"></div>
		{{/if}}
		{{/if}}
	</div>
</header>

<div id="index" class="container" style="position: relative;">

	{{^is "paged"}}
	<div class="tag-go-back-wrapper">
		<a href="/" class="post-go-back">Go Back</a>
	</div>
	{{/is}}

	<main class="content" role="main">

		{{> "loop"}}

	</main>

</div>
